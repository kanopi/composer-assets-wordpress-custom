# tugboat.env — non-secret, per-project Tugboat variables (committed, seeded once).
# Dashboard env vars of the same name win; SECRETS (DB_REMOTE_PASS) go in the dashboard.

# --- Project basics --------------------------------------------------------
: "${CMS:=wordpress}"
: "${PROJECT_DOCROOT:=}"                  # classic WP at repo root; "web" for Bedrock
: "${TABLE_PREFIX:=wp_}"
: "${WP_MULTISITE:=false}"                # true for a WordPress multisite/network
: "${WP_MULTISITE_TYPE:=subdirectory}"    # subdirectory | subdomain (subdomain needs wildcard DNS)

# --- Front-end build -------------------------------------------------------
: "${BUILD_THEME:=true}"
: "${NODE_PACKAGE_MANAGER:=npm}"        # "npm" or "yarn"
: "${NODE_VERSION:=20.11.0}"             # installed in the preview via nvm
: "${THEME_PATH:=wp-content/themes/mytheme}"
: "${THEME_BUILD_COMMAND:=build}"

# --- Production URL (search-replace + file proxy) --------------------------
: "${PROD_URL:=https://www.example.com}"

# --- File handling (both conditions are independent) -----------------------
: "${FILES_PROXY:=true}"                  # serve missing uploads from PROD_URL (no copy)
: "${FILES_RSYNC:=false}"                 # rsync wp-content/uploads down from source
: "${FILES_REMOTE_PATH:=}"                # source uploads dir, e.g. /var/www/prod/wp-content/uploads

# --- Source database (over SSH; add the SSH key in the dashboard) ----------
: "${DB_SSH_USER:=deploy}"
: "${DB_SSH_HOST:=prod.example.com}"
: "${DB_SSH_PORT:=22}"
: "${DB_REMOTE_HOST:=127.0.0.1}"
: "${DB_REMOTE_NAME:=}"
: "${DB_REMOTE_USER:=}"
# DB_REMOTE_PASS -> dashboard secret.
